# Application
APP_NAME="your app name"
APP_VERSION="1.0.0"
NODE_ENV=development
DOMAIN=localhost:3000
APP_PORT=3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_PREFIX=nest-template

# Notifications
NOTIFICATIONS_PROVIDER=fcm
NOTIFICATIONS_QUEUE_ATTEMPTS=3
NOTIFICATIONS_QUEUE_BACKOFF_MS=5000

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_SERVICE_ACCOUNT_JSON=
FCM_APP_NAME=notifications-fcm

# Emails
EMAILS_QUEUE_ATTEMPTS=3
EMAILS_QUEUE_BACKOFF_MS=5000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
